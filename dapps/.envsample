# Change the following to the preferred smart assembly
# If defined, this will take priority over values passed via URL query param
VITE_OBJECT_ID=

# World package id
# Default to the official Utopia world package on Sui testnet.
VITE_EVE_WORLD_PACKAGE_ID="0x07e6b810c2dff6df56ea7fbad9ff32f4d84cbee53e496267515887b712924bd1"

VITE_SUI_GRAPHQL_ENDPOINT="https://graphql.testnet.sui.io/graphql"

# Optional JSON-RPC endpoint for BaseOps transaction readback and dev-inspect helpers.
VITE_SUI_RPC_URL="https://fullnode.testnet.sui.io:443"
VITE_BASEOPS_LOCALNET_RPC_URL="http://127.0.0.1:9000"

# Optional BaseOps runtime defaults. These can also be edited live in the UI and are persisted in localStorage.
VITE_BASEOPS_DEFAULT_NETWORK="testnet"
VITE_BASEOPS_TENANT="utopia"
# For live writes on the official Utopia world, publish your extension against the
# Utopia world package and paste the resulting IDs below. The values here are the
# latest package published from this repo against official Utopia; route-specific
# authorization and object IDs still need to be supplied from a live Utopia setup.
VITE_BASEOPS_BUILDER_PACKAGE_ID="0x34c884b88860af000965b80eebe74c52a6a64d79b44a70b77278d44e436aab56"
VITE_BASEOPS_EXTENSION_CONFIG_ID="0xb395adba3e55fabcaaa7f200d068224e01f43b59732c8a69b7f6d6c8187942e4"
VITE_BASEOPS_SOURCE_GATE_OBJECT_ID=""
VITE_BASEOPS_SOURCE_GATE_ITEM_ID=""
VITE_BASEOPS_DESTINATION_GATE_OBJECT_ID=""
VITE_BASEOPS_DESTINATION_GATE_ITEM_ID=""
VITE_BASEOPS_STORAGE_UNIT_OBJECT_ID=""
VITE_BASEOPS_STORAGE_UNIT_ITEM_ID=""
VITE_BASEOPS_CHARACTER_OBJECT_ID=""
VITE_BASEOPS_CHARACTER_ITEM_ID=""
VITE_BASEOPS_CORPSE_TYPE_ID=""
VITE_BASEOPS_CORPSE_QUANTITY="1"
VITE_BASEOPS_RECENT_DIGESTS=""
